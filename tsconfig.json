{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "moduleResolution": "bundler",
        "strict": true,
        "declaration": true,
        "emitDeclarationOnly": false,
        "rootDir": "./src",
        "outDir": "dist"
    },
    "include": ["src"]
}
